
<svg width="1200" height="320" viewBox="0 0 1200 320" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="glow" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#00C853" stop-opacity="0.28"/>
      <stop offset="45%" stop-color="#0D4429" stop-opacity="0.45"/>
      <stop offset="100%" stop-color="#020617" stop-opacity="1"/>
    </radialGradient>

    <linearGradient id="lineGradient" x1="0" y1="0" x2="1200" y2="320">
      <stop offset="0%" stop-color="#00C853" stop-opacity="0.15"/>
      <stop offset="50%" stop-color="#22C55E" stop-opacity="0.65"/>
      <stop offset="100%" stop-color="#38BDF8" stop-opacity="0.18"/>
    </linearGradient>

    <filter id="blurGlow">
      <feGaussianBlur stdDeviation="3.5" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <style>
      .line {
        stroke: url(#lineGradient);
        stroke-width: 1.2;
        opacity: 0.48;
        stroke-dasharray: 8 12;
        animation: dash 9s linear infinite;
      }

      .dot {
        fill: #00C853;
        filter: url(#blurGlow);
        opacity: 0.9;
      }

      .dot-blue {
        fill: #38BDF8;
        filter: url(#blurGlow);
        opacity: 0.65;
      }

      .pulse {
        animation: pulse 3.5s ease-in-out infinite;
      }

      .pulse2 {
        animation: pulse 4.5s ease-in-out infinite;
      }

      .float {
        animation: float 7s ease-in-out infinite;
      }

      .float2 {
        animation: float2 8s ease-in-out infinite;
      }

      @keyframes dash {
        to {
          stroke-dashoffset: -160;
        }
      }

      @keyframes pulse {
        0%, 100% {
          opacity: 0.45;
          r: 3;
        }
        50% {
          opacity: 1;
          r: 5.5;
        }
      }

      @keyframes float {
        0%, 100% {
          transform: translateY(0px);
        }
        50% {
          transform: translateY(-8px);
        }
      }

      @keyframes float2 {
        0%, 100% {
          transform: translateX(0px);
        }
        50% {
          transform: translateX(10px);
        }
      }

      .title {
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 46px;
        font-weight: 800;
        fill: #ECFDF5;
        letter-spacing: -1px;
      }

      .subtitle {
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 18px;
        fill: #BBF7D0;
        opacity: 0.95;
      }

      .small {
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 14px;
        fill: #86EFAC;
        opacity: 0.9;
      }
    </style>
  </defs>

  <rect width="1200" height="320" fill="#020617"/>
  <rect width="1200" height="320" fill="url(#glow)"/>

  <g opacity="0.35">
    <circle cx="140" cy="70" r="120" fill="#00C853" opacity="0.08"/>
    <circle cx="970" cy="230" r="170" fill="#38BDF8" opacity="0.07"/>
    <circle cx="560" cy="160" r="220" fill="#22C55E" opacity="0.06"/>
  </g>

  <g class="float">
    <line class="line" x1="80" y1="80" x2="210" y2="45"/>
    <line class="line" x1="210" y1="45" x2="355" y2="105"/>
    <line class="line" x1="355" y1="105" x2="510" y2="70"/>
    <line class="line" x1="510" y1="70" x2="680" y2="130"/>
    <line class="line" x1="680" y1="130" x2="845" y2="75"/>
    <line class="line" x1="845" y1="75" x2="1030" y2="115"/>
    <line class="line" x1="1030" y1="115" x2="1140" y2="55"/>

    <line class="line" x1="130" y1="235" x2="285" y2="185"/>
    <line class="line" x1="285" y1="185" x2="430" y2="245"/>
    <line class="line" x1="430" y1="245" x2="610" y2="205"/>
    <line class="line" x1="610" y1="205" x2="760" y2="250"/>
    <line class="line" x1="760" y1="250" x2="930" y2="195"/>
    <line class="line" x1="930" y1="195" x2="1080" y2="250"/>

    <line class="line" x1="210" y1="45" x2="285" y2="185"/>
    <line class="line" x1="355" y1="105" x2="430" y2="245"/>
    <line class="line" x1="510" y1="70" x2="610" y2="205"/>
    <line class="line" x1="680" y1="130" x2="760" y2="250"/>
    <line class="line" x1="845" y1="75" x2="930" y2="195"/>
  </g>

  <g class="float2">
    <circle class="dot pulse" cx="80" cy="80" r="4"/>
    <circle class="dot pulse2" cx="210" cy="45" r="4"/>
    <circle class="dot-blue pulse" cx="355" cy="105" r="4"/>
    <circle class="dot pulse2" cx="510" cy="70" r="4"/>
    <circle class="dot-blue pulse" cx="680" cy="130" r="4"/>
    <circle class="dot pulse2" cx="845" cy="75" r="4"/>
    <circle class="dot-blue pulse" cx="1030" cy="115" r="4"/>
    <circle class="dot pulse2" cx="1140" cy="55" r="4"/>

    <circle class="dot-blue pulse" cx="130" cy="235" r="4"/>
    <circle class="dot pulse2" cx="285" cy="185" r="4"/>
    <circle class="dot-blue pulse" cx="430" cy="245" r="4"/>
    <circle class="dot pulse2" cx="610" cy="205" r="4"/>
    <circle class="dot-blue pulse" cx="760" cy="250" r="4"/>
    <circle class="dot pulse2" cx="930" cy="195" r="4"/>
    <circle class="dot-blue pulse" cx="1080" cy="250" r="4"/>
  </g>

  <g>
    <text x="600" y="145" text-anchor="middle" class="title">Miyuru Amarasiri</text>
    <text x="600" y="180" text-anchor="middle" class="subtitle">
      Business Analytics Undergraduate • Open-Source Maintainer • AI & Cybersecurity Explorer
    </text>
    <text x="600" y="214" text-anchor="middle" class="small">
      🇱🇰 Building from Sri Lanka • Learning globally • Contributing openly
    </text>
  </g>
</svg>
